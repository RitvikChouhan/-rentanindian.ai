<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>rentanindian.ai — From AI to reality. Tasks executed.</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
:root{
  --sky:#2E8CE8;--sky-d:#1A6FC4;--sky-l:#5BA8F0;
  --sky-pale:#EEF6FF;--sky-tint:#F4F9FF;--sky-stripe:#E8F3FD;--sky-mid:#D4EAFF;
  --orange:#F56C1D;--orange-h:#D95A0D;--orange-glow:rgba(245,108,29,.3);
  --green:#22C55E;--green-dim:rgba(34,197,94,.15);
  --ink:#0A0E1A;--ink2:#1E293B;--ink3:#64748B;--ink4:#94A3B8;
  --white:#fff;--border:#E2E8F0;--border-sky:#C8DFF7;
  --fd:'Sora',sans-serif;--fb:'DM Sans',sans-serif;--fm:'JetBrains Mono',monospace;
  --r:12px;--rl:18px;--rx:24px;
  --sh:0 2px 12px rgba(0,0,0,.07),0 6px 24px rgba(0,0,0,.05);
  --sh-sky:0 6px 28px rgba(46,140,232,.2);
  --sh-lift:0 10px 44px rgba(0,0,0,.13);
  --sh-orange:0 6px 24px rgba(245,108,29,.35);
  --sh-green:0 4px 20px rgba(34,197,94,.25);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--fb);color:var(--ink);background:#fff;-webkit-font-smoothing:antialiased}
img,svg{display:block}
.page{display:none;min-height:100vh;flex-direction:column}
.page.active{display:flex}

/* ════ NAV (PATCH 4: new labels) ════ */
#gnav{
  position:fixed;top:0;left:0;right:0;z-index:200;
  height:64px;padding:0 40px;
  display:flex;align-items:center;justify-content:space-between;
  background:rgba(255,255,255,.95);
  backdrop-filter:blur(20px) saturate(1.6);
  border-bottom:1px solid rgba(220,230,242,.7);
  transition:box-shadow .25s;
}
#gnav.scrolled{box-shadow:0 2px 32px rgba(0,0,0,.1)}
.nav-logo{font-family:var(--fd);font-size:15.5px;font-weight:700;color:var(--ink);letter-spacing:-.02em;cursor:pointer;transition:opacity .15s;user-select:none}
.nav-logo:hover{opacity:.72}
.nav-logo span{color:var(--sky)}
.nav-links{display:flex;align-items:center;gap:2px}
.nl{
  font-size:13px;font-weight:700;color:var(--ink);
  text-decoration:none;cursor:pointer;padding:6px 12px;border-radius:9px;
  position:relative;transition:color .18s,background .18s;letter-spacing:-.005em;
}
.nl::after{content:'';position:absolute;bottom:4px;left:12px;right:12px;height:1.5px;background:var(--sky);border-radius:2px;transform:scaleX(0);transform-origin:left;transition:transform .22s cubic-bezier(.4,0,.2,1)}
.nl:hover{color:var(--sky);background:rgba(46,140,232,.06)}
.nl:hover::after{transform:scaleX(1)}
.nl.active-page{color:var(--sky)}
.nl.active-page::after{transform:scaleX(1)}
.nav-r{display:flex;align-items:center;gap:8px}
.btn-ghost{font-family:var(--fb);font-size:13.5px;font-weight:600;color:var(--ink2);background:none;border:1.5px solid var(--border);cursor:pointer;padding:7px 16px;border-radius:9px;transition:all .2s}
.btn-ghost:hover{background:var(--sky-tint);color:var(--sky);border-color:var(--sky-l);transform:translateY(-1px)}
.btn-cta{font-family:var(--fb);font-size:13.5px;font-weight:700;color:#fff;background:var(--orange);border:none;cursor:pointer;padding:8px 22px;border-radius:9px;box-shadow:0 2px 10px var(--orange-glow);transition:all .2s;letter-spacing:.01em}
.btn-cta:hover{background:var(--orange-h);transform:translateY(-2px);box-shadow:var(--sh-orange)}
.btn-cta:active{transform:translateY(0)}

/* ════ HERO (PATCH 0 + 1 + 2 + 3) ════ */
.hero{
  min-height:100vh;padding:100px 40px 80px;
  background:linear-gradient(158deg,#0C52A0 0%,#1568BF 15%,#2680D4 32%,#2E8CE8 46%,#5AAEF5 66%,#B8D9FA 82%,#EBF5FF 100%);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  text-align:center;position:relative;overflow:hidden;
}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 75% 60% at 50% 38%,rgba(255,255,255,.16) 0%,transparent 65%);pointer-events:none}
.hero::after{content:'';position:absolute;bottom:-1px;left:0;right:0;height:80px;background:linear-gradient(to bottom,transparent,var(--sky-tint));pointer-events:none}
.hero-badge{display:inline-flex;align-items:center;gap:9px;background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.3);border-radius:100px;padding:5px 16px 5px 11px;margin-bottom:28px;font-size:11px;font-weight:700;color:rgba(255,255,255,.95);letter-spacing:.08em;text-transform:uppercase;backdrop-filter:blur(10px)}
.bdot{width:7px;height:7px;border-radius:50%;background:#7EFFC0;flex-shrink:0;animation:pdot 2.2s ease-in-out infinite}
@keyframes pdot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.8)}}

/* PATCH 0: hero h1 */
.hero h1{
  font-family:var(--fd);font-size:clamp(42px,6.5vw,78px);font-weight:800;
  color:#fff;line-height:1.04;letter-spacing:-.04em;margin-bottom:20px;max-width:800px;
}
.hero h1 .from{color:rgba(255,255,255,.65);font-weight:700}
.hero-sub{font-size:clamp(15px,2vw,18px);font-weight:400;color:rgba(255,255,255,.8);max-width:500px;line-height:1.7;margin-bottom:12px}
/* PATCH 0: supporting sample tasks line */
.hero-samples{
  font-size:12.5px;color:rgba(255,255,255,.46);margin-bottom:40px;
  font-family:var(--fm);letter-spacing:.01em;max-width:580px;line-height:1.9;
}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap;justify-content:center;margin-bottom:20px}
.btn-hp{font-family:var(--fb);font-size:15.5px;font-weight:700;color:#fff;background:var(--orange);border:none;cursor:pointer;padding:15px 34px;border-radius:12px;letter-spacing:.01em;box-shadow:0 4px 24px rgba(245,108,29,.48);transition:all .22s}
.btn-hp:hover{background:var(--orange-h);transform:translateY(-3px);box-shadow:0 8px 32px rgba(245,108,29,.55)}
.btn-hp:active{transform:translateY(-1px)}
.btn-hs{font-family:var(--fb);font-size:15.5px;font-weight:600;color:rgba(255,255,255,.95);background:rgba(255,255,255,.14);border:2px solid rgba(255,255,255,.38);cursor:pointer;padding:15px 34px;border-radius:12px;transition:all .22s;backdrop-filter:blur(8px)}
.btn-hs:hover{background:rgba(255,255,255,.26);border-color:rgba(255,255,255,.6);transform:translateY(-3px)}

/* PATCH 1: live activity pills */
.hero-activity{
  display:flex;gap:10px;flex-wrap:wrap;justify-content:center;margin-bottom:18px;
}
.activity-pill{
  display:inline-flex;align-items:center;gap:7px;
  background:rgba(0,0,0,.22);border:1px solid rgba(255,255,255,.14);
  border-radius:100px;padding:5px 13px;
  font-size:12px;font-weight:500;color:rgba(255,255,255,.78);
  backdrop-filter:blur(8px);
}
.activity-pill .adot{width:6px;height:6px;border-radius:50%;background:#22C55E;flex-shrink:0;box-shadow:0 0 6px rgba(34,197,94,.8);animation:pdot 1.8s ease-in-out infinite}

/* PATCH 2: agent viral line */
.hero-agent-row{
  display:flex;align-items:center;gap:10px;justify-content:center;flex-wrap:wrap;
}
.hero-agent-note{font-size:12.5px;color:rgba(255,255,255,.5);letter-spacing:.01em;display:flex;align-items:center;gap:6px}
.hero-agent-note .ndot{width:5px;height:5px;border-radius:50%;background:rgba(126,255,192,.6);flex-shrink:0}
.hero-viral{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.18);
  border-radius:8px;padding:5px 12px;cursor:pointer;
  font-family:var(--fm);font-size:11.5px;color:rgba(255,255,255,.75);
  transition:all .18s;position:relative;
}
.hero-viral:hover{background:rgba(255,255,255,.18);color:#fff;border-color:rgba(255,255,255,.35)}
.hero-viral .copy-icon{font-size:10px;opacity:.6}
.hero-viral .copied-toast{
  position:absolute;top:-30px;left:50%;transform:translateX(-50%);
  background:rgba(0,0,0,.7);color:#7EFFC0;font-size:10px;padding:3px 10px;
  border-radius:6px;white-space:nowrap;opacity:0;transition:opacity .2s;pointer-events:none;
}
.hero-viral.copied .copied-toast{opacity:1}

/* ════ TRUST STRIP ════ */
.trust-strip{background:var(--sky-stripe);border-bottom:1px solid var(--border-sky);padding:14px 40px;display:flex;justify-content:center;gap:52px;flex-wrap:wrap}
.ti{display:flex;align-items:center;gap:10px;font-size:13px;font-weight:600;color:var(--ink2)}
.ti-c{width:20px;height:20px;border-radius:50%;background:rgba(46,140,232,.12);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.ti-c svg{color:var(--sky)}

/* PATCH 10: language strip */
.lang-strip{background:var(--sky-pale);border-bottom:1px solid var(--border-sky);padding:10px 40px;display:flex;justify-content:center;align-items:center;flex-wrap:wrap}
.lang-item{font-size:13px;font-weight:500;color:var(--ink3);padding:0 18px;border-right:1px solid var(--border-sky);letter-spacing:.01em}
.lang-item:last-child{border-right:none}
.lang-item strong{color:var(--ink2);font-weight:600}

/* ════ SECTION UTIL ════ */
.wrap{max-width:1120px;margin:0 auto;width:100%;padding:96px 40px}
.sl{font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--sky);margin-bottom:14px}
.st{font-family:var(--fd);font-size:clamp(28px,4vw,46px);font-weight:800;color:var(--ink);letter-spacing:-.03em;line-height:1.09;margin-bottom:18px}
.ss{font-size:17px;font-weight:300;color:var(--ink3);line-height:1.75;max-width:560px}
.ctr{text-align:center}.ctr .ss{margin:0 auto}
.bg-w{background:#fff}.bg-t{background:var(--sky-tint)}.bg-s{background:var(--sky-stripe)}.bg-p{background:var(--sky-pale)}.bg-dk{background:var(--ink)}

/* ════ PATCH 5: LIVE BOUNTIES SECTION ════ */
.bounties-section{background:var(--sky-tint);padding:96px 40px}
.bounties-inner{max-width:1120px;margin:0 auto}
.bounties-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:32px;flex-wrap:wrap;gap:16px}
.live-indicator{display:flex;align-items:center;gap:7px;font-size:12px;font-weight:600;color:var(--green);letter-spacing:.04em;text-transform:uppercase}
.live-dot{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 8px rgba(34,197,94,.7);animation:pdot 1.6s ease-in-out infinite}
.bounty-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
.bounty-card{
  background:#fff;border:1px solid var(--border);border-radius:var(--rl);
  padding:24px;transition:all .22s;cursor:pointer;display:flex;flex-direction:column;gap:10px;
}
.bounty-card:hover{border-color:var(--sky);transform:translateY(-4px);box-shadow:var(--sh-sky)}
.b-tag-row{display:flex;align-items:center;justify-content:space-between}
.b-type{font-size:10px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;padding:3px 9px;border-radius:100px}
.b-remote{background:rgba(46,140,232,.1);color:var(--sky-d)}
.b-local{background:rgba(34,197,94,.1);color:#15803D}
.b-urgent{background:rgba(245,108,29,.1);color:var(--orange-h)}
.b-title{font-family:var(--fd);font-size:15px;font-weight:700;color:var(--ink);line-height:1.3}
.b-desc{font-size:13px;color:var(--ink3);line-height:1.6}
.b-footer{display:flex;align-items:center;justify-content:space-between;padding-top:10px;border-top:1px solid var(--border);margin-top:auto}
.b-price{font-family:var(--fd);font-size:16px;font-weight:800;color:var(--ink)}
.b-price .currency{font-size:11px;font-weight:600;color:var(--ink3);margin-right:2px}
.b-loc{display:flex;align-items:center;gap:4px;font-size:11.5px;color:var(--ink4);font-weight:500}
.b-apply{
  margin-top:4px;width:100%;font-family:var(--fb);font-size:13px;font-weight:600;
  color:var(--sky);background:var(--sky-pale);border:1px solid var(--border-sky);
  border-radius:8px;padding:8px;cursor:pointer;transition:all .18s;letter-spacing:.01em;
}
.b-apply:hover{background:var(--sky);color:#fff;border-color:var(--sky)}
.bounties-cta{text-align:center;margin-top:40px;display:flex;gap:12px;justify-content:center;flex-wrap:wrap}

/* ════ PATCH 6: REQUEST A TASK SECTION ════ */
.request-section{background:var(--ink);padding:96px 40px}
.request-inner{max-width:1120px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center}
.request-left .sl{color:#5BADFF}
.request-left .st{color:#fff}
.request-left .ss{color:rgba(255,255,255,.52)}
.request-features{list-style:none;margin-top:28px;display:flex;flex-direction:column;gap:12px}
.request-features li{display:flex;align-items:center;gap:12px;font-size:14px;color:rgba(255,255,255,.65);line-height:1.6}
.request-features li::before{content:'';width:6px;height:6px;border-radius:50%;background:#5BADFF;flex-shrink:0}
.request-form{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:var(--rx);padding:36px}
.rf-label{display:block;font-size:11.5px;font-weight:700;color:rgba(255,255,255,.5);letter-spacing:.08em;text-transform:uppercase;margin-bottom:7px}
.rf-input,.rf-textarea,.rf-select{
  width:100%;font-family:var(--fb);font-size:14px;
  background:rgba(255,255,255,.07);border:1.5px solid rgba(255,255,255,.1);
  border-radius:10px;padding:11px 14px;color:#fff;outline:none;
  transition:border .18s,background .18s;margin-bottom:16px;
}
.rf-textarea{resize:vertical;min-height:90px}
.rf-input:focus,.rf-textarea:focus,.rf-select:focus{border-color:rgba(91,173,255,.6);background:rgba(255,255,255,.1)}
.rf-input::placeholder,.rf-textarea::placeholder{color:rgba(255,255,255,.3)}
.rf-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.rf-submit{
  width:100%;font-family:var(--fb);font-size:15px;font-weight:700;color:#fff;
  background:var(--orange);border:none;cursor:pointer;
  padding:13px;border-radius:11px;
  box-shadow:0 4px 16px var(--orange-glow);transition:all .2s;letter-spacing:.01em;
}
.rf-submit:hover{background:var(--orange-h);transform:translateY(-2px);box-shadow:var(--sh-orange)}

/* ════ SERVICES GRID (PATCH 10) ════ */
.services-section{background:#fff;padding:96px 40px}
.services-inner{max-width:1120px;margin:0 auto}
.services-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:56px}
.service-card{
  background:#fff;border:1.5px solid var(--border);border-radius:var(--rl);
  padding:28px 22px;transition:all .24s;cursor:pointer;
}
.service-card:hover{border-color:var(--sky);transform:translateY(-5px);box-shadow:var(--sh-sky)}
.sc-icon{width:50px;height:50px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:24px;margin-bottom:14px}
.si-blue{background:linear-gradient(135deg,#EEF6FF,#CCDDF7)}
.si-amber{background:linear-gradient(135deg,#FFF8EE,#FFEACC)}
.si-green{background:linear-gradient(135deg,#EDFFF6,#C0F0D8)}
.si-purple{background:linear-gradient(135deg,#F3F0FF,#DDD6FE)}
.si-red{background:linear-gradient(135deg,#FFF1F0,#FFD6D3)}
.si-teal{background:linear-gradient(135deg,#EDFCFF,#C0EFF7)}
.si-orange{background:linear-gradient(135deg,#FFF4EE,#FFE0CC)}
.si-pink{background:linear-gradient(135deg,#FFF0F8,#FFD6EE)}
.sc-title{font-family:var(--fd);font-size:14.5px;font-weight:700;color:var(--ink);margin-bottom:7px}
.sc-desc{font-size:13px;color:var(--ink3);line-height:1.6}
.sc-type{display:inline-block;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:2px 8px;border-radius:100px;margin-top:10px}
.sc-digital{background:rgba(46,140,232,.08);color:var(--sky-d)}
.sc-physical{background:rgba(34,197,94,.1);color:#15803D}
.service-link{
  display:inline-flex;align-items:center;gap:5px;
  font-size:12.5px;font-weight:700;color:var(--sky);margin-top:14px;
  transition:gap .2s;
}
.service-card:hover .service-link{gap:9px}

/* ════ CAPABILITY CARDS ════ */
.cap-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:56px}
.cap-card{background:#fff;border:1.5px solid var(--border-sky);border-radius:var(--rl);padding:32px;transition:all .24s;cursor:default}
.cap-card:hover{border-color:var(--sky-l);transform:translateY(-5px);box-shadow:var(--sh-sky)}
.cc-lbl{font-size:10.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--sky);font-weight:700;margin-bottom:10px}
.cc-from{font-family:var(--fd);font-size:21px;font-weight:700;color:var(--ink);margin-bottom:10px}
.cc-arr{color:var(--sky);font-size:22px;margin:12px 0;line-height:1}
.cc-to{font-size:14px;color:var(--ink3);line-height:1.65}

/* ════ EXECUTION TERMINAL ════ */
.exec-section{background:var(--sky-tint);padding:96px 40px}
.exec-inner{max-width:1120px;margin:0 auto}
.exec-terminal{background:#0C1018;border:1px solid rgba(255,255,255,.07);border-radius:var(--rx);overflow:hidden;margin-top:56px;box-shadow:0 28px 72px rgba(0,0,0,.3)}
.term-hdr{background:#151B25;padding:14px 22px;display:flex;align-items:center;gap:7px;border-bottom:1px solid rgba(255,255,255,.05)}
.tdot{width:12px;height:12px;border-radius:50%}
.tr{background:#FF5F57}.ty{background:#FFBD2E}.tg{background:#28C940}
.term-lbl{font-family:var(--fd);font-size:11px;color:rgba(255,255,255,.28);letter-spacing:.09em;margin-left:10px;text-transform:uppercase}
.term-body{padding:40px 48px;display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center}
.term-code{font-family:'Courier New',monospace;font-size:13.5px;line-height:2.15}
.tk{color:#7DD3FC}.tv{color:#86EFAC}.tc{color:rgba(255,255,255,.22)}.tn{color:#FDB97D}.tdim{color:rgba(255,255,255,.3)}.tgreen{color:#86EFAC}
.term-vis{display:flex;flex-direction:column;gap:4px}
.tv-step{display:flex;align-items:center;gap:16px;padding:14px 18px;border-radius:12px;border:1px solid rgba(255,255,255,.06);transition:all .2s}
.tv-step:hover{border-color:rgba(91,173,255,.3);background:rgba(91,173,255,.05)}
.tv-icon{width:38px;height:38px;border-radius:10px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:16px}
.ic-ai{background:rgba(91,173,255,.12)}.ic-task{background:rgba(253,185,125,.12)}.ic-human{background:rgba(134,239,172,.12)}.ic-done{background:rgba(167,139,250,.12)}
.tv-title{font-size:13px;font-weight:600;color:rgba(255,255,255,.85)}
.tv-sub{font-size:11.5px;color:rgba(255,255,255,.3);margin-top:2px}
.tv-badge{margin-left:auto;font-size:10px;font-weight:700;letter-spacing:.07em;padding:3px 9px;border-radius:100px}
.b-live{background:rgba(134,239,172,.12);color:#86EFAC}
.b-done{background:rgba(91,173,255,.12);color:#7DD3FC}
.tv-connector{width:1.5px;height:14px;background:rgba(255,255,255,.07);margin-left:36px}

/* ════ DARK AI FLOW ════ */
.flow-section{background:var(--ink);padding:96px 40px}
.flow-inner{max-width:1120px;margin:0 auto}
.flow-section .sl{color:#5BADFF}
.flow-section .st{color:#fff}
.flow-section .ss{color:rgba(255,255,255,.5)}
.flow-row{display:flex;align-items:stretch;margin-top:56px;border:1px solid rgba(255,255,255,.08);border-radius:var(--rl);overflow:hidden}
.flow-step{flex:1;padding:36px 24px;text-align:center;border-right:1px solid rgba(255,255,255,.06);transition:background .2s}
.flow-step:hover{background:rgba(255,255,255,.03)}
.flow-step:last-child{border-right:none}
.fs-num{width:34px;height:34px;border-radius:50%;background:rgba(91,173,255,.15);border:1px solid rgba(91,173,255,.3);display:flex;align-items:center;justify-content:center;font-size:12.5px;font-weight:700;color:#5BADFF;margin:0 auto 14px}
.fs-title{font-family:var(--fd);font-size:14.5px;font-weight:700;color:#fff;margin-bottom:8px}
.fs-sub{font-size:12.5px;color:rgba(255,255,255,.36);line-height:1.65}

/* ════ HOW IT WORKS ════ */
