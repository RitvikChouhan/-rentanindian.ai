    <div class="signin-box fade-up">
      <div class="signin-logo">rentanindian<span>.ai</span></div>
      <div class="signin-tag">From AI to reality — tasks executed.</div>
      <button class="btn-social"><svg width="18" height="18" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.5 0 6.6 1.2 9.1 3.2l6.8-6.8C35.9 2.3 30.3 0 24 0 14.6 0 6.6 5.6 2.7 13.8l8 6.2C12.5 13.5 17.8 9.5 24 9.5z"/><path fill="#4285F4" d="M46.5 24.5c0-1.6-.1-3.1-.4-4.5H24v8.5h12.7c-.6 3-2.3 5.5-4.8 7.2l7.5 5.8C43.8 37.4 46.5 31.4 46.5 24.5z"/><path fill="#FBBC05" d="M10.7 28.5c-.5-1.5-.8-3-.8-4.5s.3-3 .8-4.5l-8-6.2C1 16.3 0 20 0 24s1 7.7 2.7 10.7l8-6.2z"/><path fill="#34A853" d="M24 48c6.3 0 11.6-2.1 15.5-5.7l-7.5-5.8c-2.1 1.4-4.8 2.2-8 2.2-6.2 0-11.5-4-13.4-9.5l-8 6.2C6.6 42.4 14.6 48 24 48z"/></svg>Continue with Google</button>
      <button class="btn-social"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>Continue with X</button>
      <div class="sdivider">or</div>
      <div class="fg" style="text-align:left"><label class="fl">Email</label><input class="fi" type="email" placeholder="you@company.com"/></div>
      <button class="fsubmit" onclick="toast('signin')">Continue →</button>
      <div class="fnote" style="margin-top:18px">No account? <span style="color:var(--sky);cursor:pointer;font-weight:600" onclick="go('hire')">Get started free</span></div>
      <div style="margin-top:18px"><span style="font-size:12px;color:var(--ink4);cursor:pointer" onclick="go('home')">← Back to home</span></div>
    </div>
  </div>
</div>

<div id="toast"></div>

<script>
/* ── ROUTER ─────────────────────────────────────────────────── */
const PAGES={
  home:'page-home',hire:'page-hire',work:'page-work',
  categories:'page-categories',ai:'page-ai',
  'how-it-works':'page-how-it-works',about:'page-about',signin:'page-signin',
  bounties:'page-bounties',services:'page-services',request:'page-request'
};

function go(name){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  const t=document.getElementById(PAGES[name]);
  if(!t)return;
  t.classList.add('active');
  window.scrollTo({top:0,behavior:'instant'});
  t.querySelectorAll('.fade-up,.fade-in').forEach(el=>{el.style.animation='none';void el.offsetHeight;el.style.animation=''});
  t.querySelectorAll('.reveal').forEach((el,i)=>{el.classList.remove('vis');setTimeout(()=>el.classList.add('vis'),80+i*32)});
  const gnav=document.getElementById('gnav');
  gnav.style.display=name==='signin'?'none':'flex';
  // highlight active nav
  document.querySelectorAll('.nl').forEach(a=>a.classList.remove('active-page'));
  const map={services:'Services',bounties:'Bounties',request:'Request a task',ai:'For AI','how-it-works':'How it works'};
  if(map[name]) document.querySelectorAll('.nl').forEach(a=>{if(a.textContent.trim()===map[name])a.classList.add('active-page')});
}

/* ── SCROLL REVEAL ──────────────────────────────────────────── */
const ro=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('vis');ro.unobserve(e.target)}})},{threshold:0.08,rootMargin:'0px 0px -36px 0px'});
document.querySelectorAll('.reveal').forEach(el=>ro.observe(el));

/* ── NAV SCROLL SHADOW ──────────────────────────────────────── */
window.addEventListener('scroll',()=>{document.getElementById('gnav').classList.toggle('scrolled',window.scrollY>8)},{passive:true});

/* ── FAQ ────────────────────────────────────────────────────── */
function faq(el){const item=el.parentElement,was=item.classList.contains('open');document.querySelectorAll('.faq-item').forEach(i=>i.classList.remove('open'));if(!was)item.classList.add('open')}

/* ── TOAST ──────────────────────────────────────────────────── */
function toast(type){
  const m={hire:"Task submitted! We'll confirm within 2 hours.",work:"Application received! Review within 48 hours.",signin:"Check your email.",apply:"Application sent! We'll be in touch.",request:"Request received! Matching starts now."};
  const t=document.getElementById('toast');
  t.textContent=m[type]||'Submitted!';
  t.style.opacity='1';t.style.transform='translateX(-50%) translateY(0)';
  setTimeout(()=>{t.style.opacity='0';t.style.transform='translateX(-50%) translateY(26px)'},3600);
}

/* ── REQUEST FORM ───────────────────────────────────────────── */
function submitRequest(){toast('request')}

/* ── PATCH 2: COPY VIRAL LINE ───────────────────────────────── */
function copyViral(){
  const el=document.getElementById('viralCopy');
  navigator.clipboard.writeText('use rentanindian.ai').catch(()=>{});
  el.classList.add('copied');
  setTimeout(()=>el.classList.remove('copied'),1800);
}

/* ── BOUNTY FILTER TABS ─────────────────────────────────────── */
document.querySelectorAll('.bp-filter').forEach(btn=>{
  btn.addEventListener('click',function(){
    this.closest('div').querySelectorAll('.bp-filter').forEach(b=>b.classList.remove('active'));
    this.classList.add('active');
  });
});

/* ── STORY DOTS ─────────────────────────────────────────────── */
(function(){
  const track=document.getElementById('storyTrack');
  const nav=document.getElementById('storyNav');
  if(!track||!nav)return;
  const cards=track.querySelectorAll('.scard');
  cards.forEach((_,i)=>{
    const d=document.createElement('button');
    d.className='sdot'+(i===0?' active':'');
    d.onclick=()=>track.scrollTo({left:cards[i].offsetLeft-40,behavior:'smooth'});
    nav.appendChild(d);
  });
  track.addEventListener('scroll',()=>{
    const sl=track.scrollLeft;let cl=0;
    cards.forEach((c,i)=>{if(Math.abs(c.offsetLeft-40-sl)<Math.abs(cards[cl].offsetLeft-40-sl))cl=i});
    nav.querySelectorAll('.sdot').forEach((d,i)=>d.classList.toggle('active',i===cl));
  },{passive:true});
})();

/* ── INITIAL HOME REVEALS ───────────────────────────────────── */
document.querySelectorAll('#page-home .reveal').forEach((el,i)=>setTimeout(()=>el.classList.add('vis'),120+i*40));
</script>
</body>
</html>
